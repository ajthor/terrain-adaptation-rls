// For format details, see https://aka.ms/devcontainer.json.
// For config options, see https://github.com/devcontainers/templates/tree/main/src/python.
{
	"name": "Terrain Adaptation RLS",
	"image": "mcr.microsoft.com/devcontainers/python:1-3.12-bullseye",

	"runArgs": ["--gpus", "all"],

	"mounts": [
		"source=/store/${localEnv:B2B_STORE_USER:${localEnv:USER}},target=/store/${localEnv:B2B_STORE_USER:${localEnv:USER}},type=bind,consistency=cached"
	],

	"features": {
		"ghcr.io/devcontainers/features/node:1": {}
	},

	"postCreateCommand": "pip3 install --user -r requirements.txt && pip3 install --user -e .",

	"containerEnv": {
		"B2B_RESULTS_DIR": "${containerWorkspaceFolder}/results"
	},

	"remoteEnv": {
		"PATH": "/home/vscode/.local/bin:/root/.local/bin:${containerEnv:PATH}"
	}
}
