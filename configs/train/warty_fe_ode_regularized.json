{
  "name": "warty_fe_ode_regularized",
  "kind": "train",
  "platform": "warty",
  "methods": [
    "fe_static",
    "fe_rls"
  ],
  "output_root": "outputs",
  "data": {
    "train_scenes": [
      "scene0",
      "scene2",
      "scene3",
      "scene4"
    ],
    "validation_scenes": [
      "scene1"
    ],
    "test_scenes": [
      "scene5"
    ],
    "split_policy": "scene_holdout"
  },
  "model": {
    "family": "function_encoder",
    "basis_type": "legacy_neural_ode",
    "n_basis": 8,
    "hidden_size": 128
  },
  "training": {
    "steps": 1000,
    "batch_size": 4,
    "learning_rate": 0.001,
    "optimizer": "adam",
    "gradient_clip_norm": 1.0,
    "n_points": 128,
    "n_example_points": 128,
    "eval_interval": 50,
    "log_interval": 25,
    "ode_regularization": {
      "kinetic_weight": 0.0001,
      "jacobian_weight": 0.00001,
      "start_step": 1,
      "ramp_steps": 100,
      "max_points": 128
    }
  },
  "evaluation": {
    "max_eval_points": 512,
    "trajectory_query_start_index": 128,
    "trajectory_example_policy": "random_scene"
  },
  "metadata": {
    "regularization_reference": "Finlay et al., How to Train Your Neural ODE: the World of Jacobian and Kinetic Regularization, arXiv:2002.02798"
  }
}
