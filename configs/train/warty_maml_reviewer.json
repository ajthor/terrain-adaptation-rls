{
  "name": "warty_maml_reviewer",
  "kind": "train",
  "platform": "warty",
  "methods": [
    "maml_online"
  ],
  "output_root": "outputs",
  "data": {
    "train_scenes": [
      "scene0",
      "scene2",
      "scene3",
      "scene4",
      "scene6",
      "scene7"
    ],
    "validation_scenes": [
      "scene5"
    ],
    "test_scenes": [
      "scene1"
    ],
    "split_policy": "scene_holdout"
  },
  "model": {
    "family": "maml_neural_ode",
    "n_basis": 8,
    "hidden_size": 128
  },
  "training": {
    "steps": 1000,
    "batch_size": 4,
    "learning_rate": 0.001,
    "gradient_clip_norm": 1.0,
    "n_points": 128,
    "n_example_points": 128,
    "inner_steps": 1,
    "inner_learning_rate": 0.01,
    "eval_interval": 50,
    "log_interval": 25
  },
  "evaluation": {
    "max_eval_points": 512,
    "trajectory_query_start_index": 128,
    "trajectory_example_policy": "random_scene"
  }
}
