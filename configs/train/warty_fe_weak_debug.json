{
  "name": "warty_fe_weak_debug",
  "kind": "train",
  "platform": "warty",
  "methods": [
    "fe_static",
    "fe_rls"
  ],
  "output_root": "outputs",
  "data": {
    "train_scenes": [
      "scene0",
      "scene2",
      "scene3",
      "scene4",
      "scene6",
      "scene7"
    ],
    "validation_scenes": [
      "scene5"
    ],
    "test_scenes": [
      "scene1"
    ],
    "split_policy": "scene_holdout"
  },
  "model": {
    "family": "function_encoder",
    "basis_type": "mlp_increment",
    "n_basis": 8,
    "hidden_size": 128
  },
  "training": {
    "steps": 4,
    "batch_size": 2,
    "learning_rate": 0.001,
    "loss": {
      "type": "hybrid_weak",
      "weak_weight": 0.1,
      "weak_context_points": 32,
      "weak_query_points": 32,
      "weak_test_functions": 8,
      "weak_ridge": 0.0001
    }
  },
  "evaluation": {
    "max_eval_points": 128,
    "trajectory_query_start_index": 32,
    "trajectory_example_policy": "random_scene"
  }
}
