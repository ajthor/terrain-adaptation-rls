{
  "name": "jackal_node_paper_direct",
  "kind": "train",
  "platform": "jackal_0770",
  "methods": [
    "node_static"
  ],
  "output_root": "outputs",
  "data": {
    "train_scenes": [
      "grass",
      "gym_floor",
      "ice",
      "mulch",
      "pavement",
      "turf"
    ],
    "validation_scenes": [
      "short_bags/mulch"
    ],
    "test_scenes": [
      "short_bags/ice",
      "ice_autonomy_11"
    ],
    "split_policy": "legacy_jackal_paper_direct"
