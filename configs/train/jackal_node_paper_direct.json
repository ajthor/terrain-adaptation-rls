    "n_basis": 8,
    "hidden_size": 128
  },
  "training": {
    "steps": 10000,
    "batch_size": 32,
    "learning_rate": 0.001,
    "gradient_clip_norm": 1.0,
    "n_points": 1000,
    "n_example_points": 100,
    "eval_interval": 250,
    "log_interval": 250
  },
  "evaluation": {
    "max_eval_points": 1024,
    "trajectory_query_start_index": 100,
    "trajectory_example_policy": "random_scene"
  }
