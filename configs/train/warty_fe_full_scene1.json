{
  "name": "warty_fe_full_scene1",
  "kind": "train",
  "platform": "warty",
  "methods": [
    "fe_static",
    "fe_rls"
  ],
  "output_root": "outputs",
  "data": {
    "train_scenes": [
      "scene0",
      "scene2",
      "scene3",
      "scene4",
      "scene6",
      "scene7"
    ],
    "validation_scenes": [
      "scene5"
    ],
    "test_scenes": [
      "scene1"
    ],
    "split_policy": "scene_holdout"
  },
  "model": {
    "family": "function_encoder",
    "basis_type": "mlp_increment",
    "n_basis": 16,
    "hidden_size": 256
  },
  "training": {
    "steps": 20000,
    "batch_size": 8,
    "learning_rate": 0.0005,
    "optimizer": "adamw",
    "weight_decay": 0.00001,
    "lr_schedule": "cosine",
    "warmup_steps": 500,
    "final_lr_fraction": 0.05,
    "gradient_clip_norm": 1.0,
    "n_points": 256,
    "n_example_points": 256,
    "eval_interval": 500,
    "log_interval": 250
  },
  "evaluation": {
    "max_eval_points": 1024,
    "trajectory_query_start_index": 256,
    "trajectory_example_policy": "random_scene"
  }
}
